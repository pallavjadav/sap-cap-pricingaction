<mvc:View xmlns:core="sap.ui.core" xmlns:mvc="sap.ui.core.mvc"  xmlns:f="sap.f" xmlns="sap.m" xmlns:macros="sap.fe.macros" xmlns:html="http://www.w3.org/1999/xhtml" controllerName="pricingaction.ext.view.Main" xmlns:macrosTable="sap.fe.macros.table">
   
  <f:DynamicPage id="FilterBarVMWithTable" class="sapUiResponsiveContentPadding">
        <f:title>
            <f:DynamicPageTitle id="DynamicPageTitle">
                <f:heading>
                    <macros:VariantManagement id="vm" for="FilterBar,LineItemTable" showSetAsDefault="true" headerLevel="H2">
                      
                    </macros:VariantManagement>
                </f:heading>
            </f:DynamicPageTitle>
        </f:title>
        <f:header>
            <f:DynamicPageHeader id="DynamicPageHeader" pinnable="true">
                <VBox id="FilterBarVBox">
                    <macros:FilterBar id="FilterBar" metaPath="/PricingActionHeader/@com.sap.vocabularies.UI.v1.SelectionFields#filterBarMacro"/>
                </VBox>
            </f:DynamicPageHeader>
        </f:header>
        <f:content>
             <macros:Table id="Table" metaPath="/PricingActionHeader/@com.sap.vocabularies.UI.v1.LineItem#tableMacro" filterBar="FilterBar" header="Pricing Action" readOnly="true">
                <macros:massEdit/>
                <macros:actions>
                    <macrosTable:Action id="day-2-day-Main.controller" key="day-2-day-Main.controller" text="Day 2 Day" press=".pressDay2Day" requiresSelection="false"/>
                    <macrosTable:Action id="mass-Main.controller" key="mass-Main.controller" text="Mass" press=".createMass" requiresSelection="false"/>
                </macros:actions>
            </macros:Table>
        </f:content>
    </f:DynamicPage>
</mvc:View>


