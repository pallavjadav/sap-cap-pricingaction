{
  "name": "pricingaction",
  "version": "1.0.0",
  "dependencies": {
    "@cap-js/change-tracking": "^2.0.1",
    "@cap-js/hana": "^2",
    "@sap/cds": "^9",
    "@sap/xssec": "^4",
    "xlsx": "^0.18.5",
    "@sap-cloud-sdk/connectivity": "^4",
    "@sap-cloud-sdk/http-client": "^4",
    "@sap-cloud-sdk/resilience": "^4"
  },
  "devDependencies": {
    "@cap-js/sqlite": "^2.4",
    "@sap/cds-dk": "^9",
    "cds-plugin-ui5": "^0.17.0",
    "mbt": "^1.2.49",
    "rimraf": "^5.0.5"
  },
  "scripts": {
    "start": "cds-serve",
    "watch-pricingaction": "cds watch --open pricingaction/index.html?sap-ui-xx-viewCache=false --livereload false",
    "undeploy": "cf undeploy pricingaction --delete-services --delete-service-keys --delete-service-brokers",
    "build": "rimraf resources mta_archives && mbt build --mtar archive",
    "deploy": "cf deploy mta_archives/archive.mtar --retries 1"
  },
  "private": true,
  "cds": {
    "requires": {
      "[production]": {
        "auth": "xsuaa"
      },
      "destinations": true,
      "html5-repo": true,
      "application-logging": true,
      "API_SALESORGANIZATION_SRV": {
        "kind": "odata-v2",
        "model": "srv/external/API_SALESORGANIZATION_SRV",
        "credentials": {
          "destination": "S4H_Sandbox_API",
          "path": "/s4hanacloud/sap/opu/odata/sap/API_SALESORGANIZATION_SRV"
        }
      },
      "API_PRODUCT_SRV": {
        "kind": "odata-v2",
        "model": "srv/external/API_PRODUCT_SRV",
        "credentials": {
          "destination": "S4H_Sandbox_API",
          "path": "/s4hanacloud/sap/opu/odata/sap/API_PRODUCT_SRV"
        }
      }
    }
  },
  "workspaces": [
    "app/*"
  ],
  "sapux": [
    "app/pricingaction"
  ]
}